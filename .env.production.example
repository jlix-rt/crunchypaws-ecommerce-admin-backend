# Producción — copia a .env en el servidor (chmod 600). Misma BD que crunchypaws-ecommerce-backend.
NODE_ENV=production

# Opcional: HTTP_LOG=0 para no registrar cada petición en PM2 / journald
PORT=4001
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@HOST:5432/crunchypaws-ecommerce"
JWT_SECRET=cambiar-minimo-32-caracteres-misma-logica-que-tienda-si-aplica
EMAIL_HOST=smtp.tu-proveedor.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="CrunchyPaws Admin <noreply@tu-dominio.com>"
ADMIN_FRONTEND_URL=https://admin.crunchypaws.tiendasgt.com
# Opcional: base pública para enlaces de verificación por correo (HTTPS). Si se omite, se usa ADMIN_FRONTEND_URL.
# ADMIN_VERIFICATION_FRONTEND_BASE_URL=https://admin.crunchypaws.tiendasgt.com
# Origen público de la tienda (sin /api): se usa para armar URLs de imágenes `/uploads/products/...`.
PUBLIC_SHOP_API_URL=https://crunchypaws.tiendasgt.com
# Ruta absoluta en el VPS donde está la carpeta uploads del API tienda (compartir imágenes de productos).
STORAGE_PATH=/var/www/crunchypaws-ecommerce/uploads
